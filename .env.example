# ============================================
# Milvus
# ============================================
MILVUS_URL=http://localhost:19530
CHUNKS_COLLECTION=chunks
ENTITY_NAME_COLLECTION=entity_name
ITEM_NAME_COLLECTION=item_name

# ============================================
# LLM / OpenAI 兼容接口
# ============================================
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-api-key
VL_MODEL=gpt-4o
LLM_DEFAULT_MODEL=gpt-4o
LLM_DEFAULT_TEMPERATURE=0.0

# ============================================
# 百炼 MCP
# ============================================
MCP_DASHSCOPE_BASE_URL_STREAMABLE=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============================================
# Embedding
# ============================================
BGE_M3_PATH=/path/to/bge-m3
BGE_M3=BAAI/bge-m3
BGE_DEVICE=cpu
BGE_FP16=0

# ============================================
# Reranker
# ============================================
BGE_RERANKER_LARGE=/path/to/bge-reranker-large
BGE_RERANKER_DEVICE=cpu
BGE_RERANKER_FP16=0

# ============================================
# MinerU
# ============================================
MINERU_BASE_URL=https://mineru.net/api/v4
MINERU_API_TOKEN=

# ============================================
# MinIO
# ============================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET_NAME=dataset-rag
MINIO_IMG_DIR=images
MINIO_SECURE=False

# ============================================
# MongoDB
# ============================================
MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=dataset_rag

# ============================================
# Neo4j
# ============================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ============================================
# 日志
# ============================================
LOG_CONSOLE_ENABLE=True
LOG_CONSOLE_LEVEL=INFO
LOG_FILE_ENABLE=True
LOG_FILE_LEVEL=INFO
LOG_FILE_RETENTION=7 days

# ============================================
# 项目根目录 (可选)
# ============================================
PROJECT_ROOT=

# ============================================
# MySQL (Docker Compose)
# ============================================
MYSQL_ROOT_PASSWORD=changeme
MYSQL_PASSWORD=changeme
